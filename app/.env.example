NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Analysis pipeline
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6
VOYAGE_API_KEY=your-voyage-api-key
# Max feedback items per run (default 100). Increase for full dataset — browser run takes longer.
ANALYSIS_MAX_ITEMS=100
# Delay between Voyage embedding batches in ms (default 22000 ≈ 3 RPM). Set to 0 after billing is active.
VOYAGE_BATCH_DELAY_MS=22000
